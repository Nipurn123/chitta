{
  "name": "@100xprompt/chitta",
  "version": "0.1.1",
  "description": "Chitta - permission-aware memory for AI agents: a knowledge-graph + vector memory MCP server with per-user access control. Runs on Bun. By 100xprompt.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "chitta": "./src/bin.ts"
  },
  "files": [
    "src",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-memory",
    "agent-memory",
    "knowledge-graph",
    "graph-rag",
    "rag",
    "vector-database",
    "permission-aware",
    "rbac",
    "access-control",
    "ai-agents"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/bin.ts",
    "test": "bun test test/",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/bin.ts --compile --outfile dist/chitta",
    "install:tools": "bun run src/bin.ts install",
    "cli": "bun run src/embedded/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.24.7"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "libsql": "^0.5.29"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
