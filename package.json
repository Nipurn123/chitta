{
  "name": "@100xprompt/chitta",
  "version": "0.5.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.24.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "libsql": "^0.5.29",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0"
  },
  "bin": {
    "chitta": "./dist/bin.js"
  },
  "description": "Chitta - permission-aware memory for AI agents: a knowledge-graph + vector memory MCP server + SDK with per-user access control. Runs on Bun. By 100xprompt.",
  "engines": {
    "bun": ">=1.0.0"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./sdk": "./src/sdk.ts",
    "./adapters/ai-tools": "./src/adapters/ai-tools.ts",
    "./adapters/langchain": "./src/adapters/langchain.ts"
  },
  "files": [
    "src",
    "dist/bin.js",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-memory",
    "agent-memory",
    "knowledge-graph",
    "graph-rag",
    "rag",
    "vector-database",
    "permission-aware",
    "rbac",
    "access-control",
    "ai-agents"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/bin.ts",
    "test": "bun test test/",
    "typecheck": "tsc --noEmit",
    "ci": "bun run typecheck && bun run test",
    "build": "bun build src/bin.ts --compile --outfile dist/chitta",
    "install:tools": "bun run src/bin.ts install",
    "cli": "bun run src/embedded/cli.ts"
  }
}